# DeployPaaS Backend — Environment Variables
# Copy this file to .env and fill in your values

# Path to the SQLite database file
DB_PATH=./deploy.db

# Secret key for signing JWT tokens (use a strong random string in production)
JWT_SECRET=change-me-with-a-long-random-secret-at-least-32-chars

# Address to listen on
ADDR=:8080

# Allowed CORS origin (frontend URL)
ORIGIN=http://localhost:5173

# ── SMTP (email invitations) ──────────────────────────────────────────────────
# Leave SMTP_HOST blank to run in dev-log mode (invitation links printed to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DeployPaaS <noreply@example.com>
# Set to "true" to use STARTTLS (recommended for port 587)
SMTP_TLS=true

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:8080/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
